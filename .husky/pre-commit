#!/bin/sh
echo "🔍 Vérification TypeScript..."
npx tsc --noEmit
if [ $? -ne 0 ]; then
  echo "❌ Erreurs TypeScript détectées. Corrige-les avant de committer."
  exit 1
fi
echo "✅ TypeScript OK"

# ── Validation des migrations Supabase ───────────────────────────────────────

# 1. Interdire la suppression de fichiers de migration.
DELETED=$(git diff --cached --name-only --diff-filter=D \
  | grep "supabase/migrations/.*\.sql$" || true)

if [ -n "$DELETED" ]; then
  echo ""
  echo "❌ Suppression de migrations Supabase interdite :"
  echo "$DELETED" | sed 's/^/   /'
  echo ""
  echo "   Les migrations appliquées au remote ne peuvent pas être supprimées."
  echo "   Pour une migration orpheline, utilisez :"
  echo "   supabase migration repair --status reverted <version>"
  echo ""
  exit 1
fi

# 2. Interdire le renommage de fichiers de migration.
RENAMED=$(git diff --cached --name-status | grep "^R" \
  | grep "supabase/migrations/.*\.sql" || true)

if [ -n "$RENAMED" ]; then
  echo ""
  echo "❌ Renommage de migrations Supabase interdit :"
  echo "$RENAMED" | sed 's/^/   /'
  echo ""
  exit 1
fi

# 3. Analyse statique et auto-correction si node est disponible.
if command -v node >/dev/null 2>&1 && [ -f "scripts/validate-supabase.mjs" ]; then
  echo "🔍 Validation des migrations (validate-supabase.mjs)..."
  node scripts/validate-supabase.mjs --fix
  VALIDATION_EXIT=$?

  # Si des corrections ont été appliquées, les ajouter au commit en cours.
  if ! git diff --quiet supabase/migrations/ 2>/dev/null; then
    echo "🔧 Auto-corrections appliquées — ajout au commit..."
    git add supabase/migrations/
  fi

  if [ $VALIDATION_EXIT -ne 0 ]; then
    echo "❌ Migrations invalides. Corrigez les erreurs ci-dessus."
    exit 1
  fi
fi

echo "✅ Migrations Supabase OK"

# ── Slugs de repas : frontend / Edge Functions / contrainte SQL ──────────────
# Ne tourne que si un commit touche un fichier lié aux repas — garde le hook
# rapide le reste du temps. Voir docs/nutrition-meal-slugs.md.
MEAL_FILES=$(git diff --cached --name-only \
  | grep -E "^(src/lib/nutrition/|supabase/functions/(_shared/meals\.ts|scan-meal/|parse-meal-text/|analyze-image/|analyze-pdf/)|supabase/migrations/.*meal)" || true)

if [ -n "$MEAL_FILES" ] && command -v node >/dev/null 2>&1; then
  echo "🔍 Vérification synchro slugs de repas (frontend / Edge Functions / DB)..."
  npx vitest run src/lib/nutrition/meals.test.ts src/lib/nutrition/meals.sync.test.ts
  if [ $? -ne 0 ]; then
    echo "❌ Les slugs de repas ont divergé. Voir docs/nutrition-meal-slugs.md."
    exit 1
  fi
  echo "✅ Slugs de repas synchronisés"
fi
